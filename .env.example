# ═══════════════════════════════════════════════════════════════════════════════
# VYZORIX UPDATE SERVER — Environment Configuration
# ═══════════════════════════════════════════════════════════════════════════════
# Copy this file to .env and fill in your values.
# Generate secrets with: openssl rand -hex 32

# ─── Server ───────────────────────────────────────────────────────────────────
PORT=3000
NODE_ENV=production
DATABASE_URL=./data/vyzorix.db
VYZORIX_API_DIR=./data
VYZORIX_BIN_DIR=./bin
VYZORIX_PUBLIC_DIR=./public

# ─── Security ────────────────────────────────────────────────────────────────
TOKEN_SECRET=replace-with-a-random-32-plus-character-dashboard-token
JWT_SECRET=replace-with-a-different-random-32-plus-character-jwt-secret
JWT_DURATION_HOURS=168
ALLOWED_ORIGINS=http://localhost:5173,https://your-dashboard.example.com,android-app://com.vyzorix.audiorouter
ENFORCE_HMAC=true
HMAC_WINDOW_SECONDS=30

# ─── Firebase (FCM Push Notifications) ───────────────────────────────────────
# Get from: Firebase Console → Project Settings → Service Accounts → Generate
FIREBASE_CREDENTIALS={"type":"service_account","project_id":"","private_key_id":"","private_key":"","client_email":"","client_id":"","auth_uri":"","token_uri":"","auth_provider_x509_cert_url":"","client_x509_cert_url":""}

# ─── Google OAuth (Optional) ───────────────────────────────────────────────────
# Get from: Google Cloud Console → APIs & Services → Credentials
# Create an OAuth 2.0 Client ID (Web application type).
# Add callback URL: https://your-domain.com/v1/auth/google/callback
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=

# ─── Email (Resend) ───────────────────────────────────────────────────────────
# Get from: https://resend.com API Keys
# Leave empty to disable email verification and password reset.
RESEND_API_KEY=
EMAIL_FROM=noreply@vyzorix.app
EMAIL_FROM_NAME=Vyzorix
EMAIL_VERIFY_TOKEN_EXPIRY_HOURS=24
PASSWORD_RESET_TOKEN_EXPIRY_MINUTES=60

# ─── Deployment URLs ───────────────────────────────────────────────────────────
# Base URL of this Go server (used to construct OAuth callback URLs)
BASE_URL=http://localhost:3000
# Frontend URL — used to redirect after OAuth flow
FRONTEND_URL=http://localhost:5173

# ─── Render Deployment ──────────────────────────────────────────────────────────
# For Render hobby plan, server sleeps after 15-30 minutes of inactivity.
# Use UptimeRobot to ping /healthz every 10 minutes to keep alive.
# Ensure /data persistent disk is configured in Render dashboard.
