PORT=3000
NODE_ENV=production
DATABASE_URL=./data/vyzorix.db
VYZORIX_API_DIR=./data
VYZORIX_BIN_DIR=./bin
VYZORIX_PUBLIC_DIR=./public
FIREBASE_CREDENTIALS={"type":"service_account","project_id":"","private_key_id":"","private_key":"","client_email":"","client_id":"","auth_uri":"","token_uri":"","auth_provider_x509_cert_url":"","client_x509_cert_url":""}
TOKEN_SECRET=replace-with-a-random-32-plus-character-dashboard-token
JWT_SECRET=replace-with-a-different-random-32-plus-character-jwt-secret
ALLOWED_ORIGINS=https://your-dashboard.example.com,android-app://com.vyzorix.audiorouter
ENFORCE_HMAC=true
HMAC_WINDOW_SECONDS=300

# ─── Auth (JWT — Go/SQLite, no Supabase required) ───────────────────────────
# JWT tokens for operator authentication. Generate with: openssl rand -hex 32
JWT_SECRET=replace-with-a-random-32-plus-character-jwt-secret
# JWT duration in hours (default: 168 = 7 days)
JWT_DURATION_HOURS=168

# ─── Google OAuth (optional — for "Sign in with Google") ─────────────────────
# Get these from: Google Cloud Console → APIs & Services → Credentials
# Create an OAuth 2.0 Client ID (Web application type).
# Add the callback URL: https://your-render-domain.onrender.com/v1/auth/google/callback
# Leave empty to disable Google OAuth (email/password still works).
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=

# ─── Deployment URLs ─────────────────────────────────────────────────────────
# Base URL of this Go server (used to construct OAuth callback URLs).
# In production on Render this would be: https://vyzorix-update-server.onrender.com
BASE_URL=http://localhost:3000
# Frontend URL — used by the Go server to redirect the browser after OAuth.
# In production this would be your Lovable Cloud frontend URL.
FRONTEND_URL=http://localhost:5173
