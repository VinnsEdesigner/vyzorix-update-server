    "vite": "^7.3.5"
  },
  "packageManager": "pnpm@11.5.2",
  "engines": {
    "node": ">=22.0.0",
    "pnpm": ">=9.0.0"
  },
  "dependencies": {
    "@tanstack/react-start-server": "^1.167.19"
  }
}
