# @vyzorix/config - .npmignore

# Source files
src/
scripts/

# Configuration files
tsconfig.json
tsconfig*.json

# Development files
*.test.ts
*.test.tsx
*.spec.ts
*.spec.tsx
**/__tests__/**
**/__mocks__/**

# Documentation
*.md
!README.md
CHANGELOG.md

# Version control
.git
.gitignore
.husky
.vscode

# Build outputs
dist/
.turbo/
.tsbuildinfo

# Dependencies
node_modules/

# IDE
.idea/
*.swp
*.swo
*~

# OS files
.DS_Store
Thumbs.db

# Logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Test coverage
coverage/
.nyc_output/

# Environment files
.env
.env.local
.env.*.local
!.env.example

# Temporary files
*.tmp
*.temp
.tmp/
tmp/

# Build artifacts
*.tgz
*.tar.gz