// @vyzorix/config/typescript/next.json - TypeScript Configuration for Next.js
{
  "$schema": "https://json.schemastore.org/tsconfig",
  "extends": "./base.json",
  "compilerOptions": {
    "target": "ES2017",
    "lib": ["dom", "dom.iterable", "esnext"],
    "allowJs": true,
    "checkJs": true,
    "jsx": "preserve",
    "noEmit": true,
    "incremental": true,
    "plugins": [
      {
        "name": "next"
      }
    ],
    "paths": {
      "@/*": ["./src/*"],
      "@vyzorix/config": ["./packages/config/src"]
    }
  },
  "include": ["src/**/*", "*.config.ts", "*.config.js", ".next/types/**/*.ts"],
  "exclude": ["node_modules"]
}